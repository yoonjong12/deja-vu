{
  "name": "deja-vu",
  "version": "0.1.0",
  "description": "Selective context preservation across Claude Code compaction — remember what matters, not everything.",
  "author": {
    "name": "yoonjong12",
    "url": "https://github.com/yoonjong12"
  },
  "homepage": "https://github.com/yoonjong12/deja-vu",
  "license": "MIT",
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.py\"",
            "timeout": 5,
            "statusMessage": "Saving session context..."
          }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/post-compact.py\"",
            "timeout": 5,
            "statusMessage": "Restoring context..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.py\"",
            "timeout": 5,
            "statusMessage": "Loading deja-vu memory..."
          }
        ]
      }
    ]
  }
}
